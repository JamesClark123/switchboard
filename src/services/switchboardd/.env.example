# switchboardd (daemon) configuration. Copy to .env for local development.
# .env is gitignored; this file is committed and documents every key.

# Stable host id advertised to clients. Defaults to the machine hostname.
SWITCHBOARDD_HOST_ID=

# Unix socket the daemon listens on (no network port is opened). When
# XDG_RUNTIME_DIR is unset (a bare `ssh host` session, cron, or a container),
# this falls back to $HOME/.local/share/switchboard/switchboard.sock.
SWITCHBOARDD_SOCKET=$XDG_RUNTIME_DIR/switchboard.sock

# PID file written while the daemon is serving. `sxbd status` and `sxbd stop`
# read it to find the running daemon. Optional; defaults next to the socket
# (same XDG_RUNTIME_DIR fallback).
SWITCHBOARDD_PID_FILE=$XDG_RUNTIME_DIR/switchboard.pid

# Controlled folder into which verbatim duplicates are copied (FR-006).
# Optional; defaults to $HOME/switchboard/workspace.
SWITCHBOARDD_WORKSPACE_ROOT=$HOME/switchboard/workspace

# Directory holding the bbolt sandbox registry (registry.db).
# Optional; defaults to $HOME/switchboard/data.
SWITCHBOARDD_DATA_DIR=$HOME/switchboard/data

# Host sandbox CLI binary used to launch/stop/destroy sandboxes.
SWITCHBOARDD_SBX_BIN=sbx

# Listen address for the agent hook callback HTTP server (sandboxes POST agent
# Stop/Notification events here via host.docker.internal:<port>).
SWITCHBOARDD_HOOK_ADDR=127.0.0.1:8765
