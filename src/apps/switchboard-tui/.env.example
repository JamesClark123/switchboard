# switchboard (TUI client) configuration. Copy to .env for local development.
# .env is gitignored; this file is committed and documents every key.

# Directory holding client TOML state (configs/, groups.toml, hosts.toml).
SWITCHBOARD_CONFIG_DIR=$XDG_CONFIG_HOME/switchboard

# Default local daemon Unix socket connected to on startup. When XDG_RUNTIME_DIR
# is unset (a bare `ssh host` session or a container), this falls back to
# $HOME/.local/share/switchboard/switchboard.sock — the same path switchboardd
# listens on, so the client and daemon stay in agreement.
SWITCHBOARD_LOCAL_SOCKET=$XDG_RUNTIME_DIR/switchboard.sock

# VS Code CLI used by the "open in VS Code" action.
SWITCHBOARD_CODE_BIN=code

# Host sandbox CLI used to open a sandbox's interactive agent terminal
# (`t` on the list runs `sbx run --name <name>`, or over ssh for a remote host).
SWITCHBOARD_SBX_BIN=sbx

# Terminal command prefix for the popout terminal (`T` on the list opens the
# sandbox session in a separate window). Empty = system default
# (x-terminal-emulator, or $TERMINAL). Examples: "kitty -e", "gnome-terminal --",
# "alacritty -e", "tmux new-window".
SWITCHBOARD_TERMINAL=
